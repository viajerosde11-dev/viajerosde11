---
import { plans } from '../data/site';

const planImages = [
  '/planes/imagenes/SanAndres.jpeg',
  '/planes/imagenes/SantaMarta.jpeg',
  '/planes/imagenes/Cartagena.jpeg',
  '/planes/imagenes/ejecafetero.jpeg',
  '/planes/imagenes/Sangil.jpeg',
  '/planes/imagenes/Santamarta-Cartagena-avion.jpeg',
  '/planes/imagenes/Santamarta-Cartagena-bus.jpeg',
];

const getImageForPlan = (index: number) => planImages[index % planImages.length];
const planCardMeta = [
  { duration: '4 DIAS / 3 NOCHES', mode: 'Aereo', icon: 'plane' },
  { duration: '4 DIAS / 3 NOCHES', mode: 'Aereo', icon: 'plane' },
  { duration: '4 DIAS / 3 NOCHES', mode: 'Aereo', icon: 'plane' },
  { duration: '4 DIAS / 3 NOCHES', mode: 'Terrestre', icon: 'car' },
  { duration: '4 DIAS / 3 NOCHES', mode: 'Terrestre', icon: 'car' },
  { duration: '5 DIAS / 4 NOCHES', mode: 'Mixto', icon: 'truck-plane' },
  { duration: '7 DIAS', mode: 'Terrestre', icon: 'car' },
] as const;
---

<section id="planes" class="relative">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ocean-dark">
          {plans.kicker}
        </p>
        <h2 class="mt-2 text-3xl font-bold text-ink md:text-4xl">
          Descubre destinos, hoteles y paquetes para  tu excursión
        </h2>
       
      </div>
    </div>

    <div class="payment-banner">
      <div class="payment-banner-media" aria-hidden="true">
        <img
          src="https://images.unsplash.com/photo-1612278675615-7b093b07772d?q=80&w=1169&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="payment-banner-copy">
        <p class="payment-banner-eyebrow">Pagos flexibles para tu promoción</p>
        <h3>Recibimos todos los medios de pago:</h3>
        <p>Transferencia, tarjeta, efectivo y bonos para pagar el 100% de tu excursion, con opciones de pago flexibles.</p>
        <div class="payment-banner-footer">
          <div class="payment-banner-icons" aria-label="Medios de pago">
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path
                  d="M6 4.5h4.1c3.28 0 5.4 1.78 5.4 4.63 0 2.83-2.12 4.6-5.4 4.6H8.8v4.77H6V4.5Z"
                  fill="#FFD24D"
                />
                <path
                  d="M6 4.5h4.1c3.28 0 5.4 1.78 5.4 4.63 0 2.83-2.12 4.6-5.4 4.6H8.8v4.77H6V4.5Z"
                  stroke="#B46A00"
                  stroke-width="1.45"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <path
                  d="M3.9 8.2h7.7M3.9 11.8h6.3"
                  stroke="#B46A00"
                  stroke-width="1.45"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect
                  x="3.3"
                  y="5.2"
                  width="17.4"
                  height="13.6"
                  rx="2.8"
                  fill="url(#cardBg)"
                />
                <path
                  d="M3.3 9.5h17.4"
                  stroke="#1C67B7"
                  stroke-width="1.2"
                  stroke-linecap="round"
                />
                <rect x="6" y="11.5" width="3.1" height="2.5" rx="0.5" fill="#FFD76A" stroke="#B78200" stroke-width="0.6" />
                <path d="M11.3 14.4h4.2" stroke="#D9F2FF" stroke-width="1.2" stroke-linecap="round" />
                <circle cx="16.7" cy="15.2" r="1.6" fill="#F7A52A" />
                <circle cx="18.5" cy="15.2" r="1.6" fill="#F25D4A" fill-opacity="0.9" />
                <rect
                  x="3.3"
                  y="5.2"
                  width="17.4"
                  height="13.6"
                  rx="2.8"
                  stroke="#0C4E8B"
                  stroke-width="1"
                />
                <defs>
                  <linearGradient id="cardBg" x1="4.2" y1="6" x2="19.8" y2="18.8" gradientUnits="userSpaceOnUse">
                    <stop stop-color="#1CA4FF" />
                    <stop offset="0.55" stop-color="#1678D5" />
                    <stop offset="1" stop-color="#0A4E9F" />
                  </linearGradient>
                </defs>
              </svg>
            </span>
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="4.2" y="6.2" width="14.6" height="9.4" rx="1.8" fill="#7CD957" stroke="#2D7C1F" stroke-width="1.1" />
                <rect x="6.1" y="8.4" width="10.8" height="5" rx="0.9" fill="#B9F18B" />
                <circle cx="12" cy="10.9" r="2.1" fill="#55B53D" />
                <path
                  d="M12.65 9.3c-.21-.18-.53-.33-.92-.33-.66 0-1.11.35-1.11.87 0 .45.33.7 1.06.86.83.19 1.22.51 1.22 1.12 0 .64-.53 1.07-1.31 1.07-.44 0-.87-.13-1.18-.37M12 8.5v4.8"
                  stroke="#F8FFF2"
                  stroke-width="1.05"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
                <circle cx="7.8" cy="17.1" r="2.3" fill="#FFC928" stroke="#C98B00" stroke-width="0.9" />
                <circle cx="10.1" cy="17.6" r="2.3" fill="#F4B300" stroke="#B67C00" stroke-width="0.9" />
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="plan-grid">
      {plans.cards.map((card, index) => {
        const meta = planCardMeta[index] ?? planCardMeta[0];
        const isLast = index === plans.cards.length - 1;
        return (
          <article
            class:list={[
              'plan-media-card',
              isLast &&
                'md:col-span-2 md:w-full md:max-w-[26rem] md:justify-self-center lg:col-span-1 lg:col-start-2 lg:max-w-none',
            ]}
          >
            <div class="plan-media-visual">
              <img
                src={getImageForPlan(index)}
                alt={card.title}
                loading="lazy"
                decoding="async"
                class="plan-media-image"
              />
              <div class="plan-media-overlay" aria-hidden="true"></div>
              <span class="plan-duration-badge">{meta.duration}</span>
            </div>
            <div class="plan-media-content">
              <p class="plan-kicker">Paquete</p>
              <h3 class="plan-title text-ink">{card.title}</h3>
              <p class="plan-mode">
                <i class:list={['fa-solid', `fa-${meta.icon}`]} aria-hidden="true"></i>
                <span>{meta.mode}</span>
              </p>
              <a
                href={card.pdf.href}
                target="_blank"
                rel="noreferrer"
                class="plan-media-cta mt-4 inline-flex items-center justify-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em]"
              >
                Ver plan
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .plan-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .payment-banner {
    margin-bottom: 1.5rem;
    overflow: hidden;
    border-radius: 0.95rem;
    border: 1px solid rgba(11, 110, 168, 0.22);
    background:
      linear-gradient(95deg, #06517c 0%, #0b6ea8 38%, #17a4c4 72%, #5cc6b0 100%);
    box-shadow: 0 14px 30px rgba(11, 110, 168, 0.12);
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    align-items: stretch;
    aspect-ratio: 640 / 51;
    min-height: 0;
  }

  .payment-banner-media {
    position: relative;
    min-height: 100%;
    overflow: hidden;
  }

  .payment-banner-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(6, 81, 124, 0.04), rgba(6, 81, 124, 0.34));
  }

  .payment-banner-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 62%;
    display: block;
  }

  .payment-banner-copy {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 0.14rem;
    padding: 0.38rem 4rem 0.4rem 0.74rem;
    color: #ffffff;
    background:
      radial-gradient(circle at top right, rgba(255, 176, 32, 0.18), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0));
  }

  .payment-banner-footer {
    position: absolute;
    right: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .payment-banner-eyebrow {
    margin: 0;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(220, 245, 255, 0.82);
  }

  .payment-banner-copy h3 {
    margin: 0;
    font-size: clamp(0.8rem, 1.2vw, 1.2rem);
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: #ffffff;
    max-width: none;
  }

  .payment-banner-copy p {
    margin: 0;
    max-width: 40ch;
    font-size: 0.62rem;
    line-height: 1.14;
    color: rgba(245, 248, 255, 0.9);
  }

  .payment-banner-icons {
    display: inline-flex;
    align-items: center;
    gap: 0.22rem;
  }

  .payment-banner-icons span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.45rem;
    height: 1.45rem;
    border-radius: 999px;
    background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.04));
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 4px 10px rgba(3, 37, 58, 0.15);
    flex: 0 0 auto;
  }

  .payment-banner-icons svg {
    width: 1.18rem;
    height: 1.18rem;
    display: block;
    overflow: visible;
  }

  .plan-media-card {
    position: relative;
    overflow: hidden;
    min-height: 100%;
    border-radius: 0.9rem;
    border: 1px solid rgba(11, 110, 168, 0.24);
    box-shadow: 0 12px 26px rgba(11, 110, 168, 0.1);
    background: linear-gradient(180deg, #eef7fb 0%, #e3f1f6 100%);
    display: grid;
    grid-template-rows: auto 1fr;
  }

  .plan-media-visual {
    position: relative;
    min-height: 14rem;
    overflow: hidden;
  }

  .plan-media-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform 0.5s ease;
  }

  .plan-media-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(2, 15, 31, 0.2) 0%, rgba(2, 15, 31, 0.06) 45%, rgba(2, 15, 31, 0) 100%),
      linear-gradient(140deg, rgba(11, 110, 168, 0.08), rgba(244, 109, 79, 0.05));
  }

  .plan-duration-badge {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    border-radius: 0.45rem;
    background: rgba(15, 23, 42, 0.82);
    color: #ffffff;
    padding: 0.38rem 0.6rem;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .plan-media-content {
    border-top: 1px solid rgba(11, 110, 168, 0.14);
    background: linear-gradient(180deg, #e4f4f8 0%, #d7ecf2 100%);
    padding: 1rem 1rem 1.15rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.7rem;
  }

  .plan-kicker {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #64748b;
  }

  .plan-title {
    margin: 0;
    font-size: clamp(1.2rem, 2.8vw, 1.75rem);
    font-weight: 800;
    line-height: 1.15;
    text-wrap: balance;
  }

  .plan-mode {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #475569;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .plan-mode i {
    color: var(--color-ocean-dark);
    font-size: 0.95rem;
  }

  .plan-media-cta {
    color: #06243a;
    background: color-mix(in srgb, var(--color-mint) 84%, white 16%);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .plan-media-card:hover .plan-media-image {
    transform: scale(1.05);
  }

  .plan-media-card:hover {
    box-shadow: 0 22px 40px rgba(11, 110, 168, 0.16);
  }

  .plan-media-card:hover .plan-media-cta {
    transform: translateY(-2px);
    filter: brightness(1.02);
  }

  @media (min-width: 768px) {
    .payment-banner-media {
      min-height: 100%;
    }

    .payment-banner-copy {
      gap: 0.18rem;
      padding: 0.44rem 5rem 0.46rem 0.86rem;
    }

    .payment-banner-eyebrow {
      font-size: 0.68rem;
    }

    .payment-banner-copy h3 {
      font-size: clamp(0.98rem, 1.25vw, 1.34rem);
      max-width: none;
    }

    .payment-banner-copy p {
      max-width: 44ch;
      font-size: 0.66rem;
      line-height: 1.14;
    }

    .payment-banner-icons {
      gap: 0.24rem;
    }

    .payment-banner-icons span {
      width: 1.62rem;
      height: 1.62rem;
    }

    .payment-banner-icons svg {
      width: 1.3rem;
      height: 1.3rem;
    }
  }

  @media (max-width: 520px) {
    .payment-banner {
      grid-template-columns: minmax(0, 0.94fr) minmax(0, 1.06fr);
      aspect-ratio: 320 / 62;
    }

    .payment-banner-copy {
      gap: 0.08rem;
      padding: 0.3rem 0.55rem 0.32rem 0.48rem;
    }

    .payment-banner-eyebrow {
      font-size: 0.46rem;
    }

    .payment-banner-copy p,
    .payment-banner-footer {
      display: none;
    }

    .payment-banner-copy h3 {
      font-size: 0.6rem;
      line-height: 1.02;
      max-width: 14ch;
    }
  }

  @media (min-width: 1024px) {
    .plan-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .plan-media-visual {
      min-height: 14.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .plan-media-image,
    .plan-media-cta {
      transition: none !important;
    }
  }
</style>
