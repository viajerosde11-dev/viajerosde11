---
import { plans } from '../data/site';

const planImages = [
  '/planes/imagenes/san-andres.jpg',
  '/planes/imagenes/santa-marta.jpg',
  '/planes/imagenes/cartagena.jpg',
  '/planes/imagenes/eje-cafetero.jpg',
  '/planes/imagenes/san-gil.jpg',
  '/planes/imagenes/santa-marta-cartagena-avion.jpg',
  '/planes/imagenes/santa-marta-cartagena-bus.jpg',
];

const getImageForPlan = (index: number) => planImages[index % planImages.length];
const chipPalette = [
  'var(--color-ocean)',
  'var(--color-coral)',
  'var(--color-mint)',
  'var(--color-sun)',
];
const getChipColor = (index: number) => chipPalette[index % chipPalette.length];

const transportIcon = {
  plane:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M21 16.5a1 1 0 0 1-1.4.9L13 14.7V18l2 1.5v1l-3-1-3 1v-1l2-1.5v-3.3L4.4 17.4A1 1 0 0 1 3 16.5l7-4V9.8L7.8 8.5v-1l3.2.8V5.5a1 1 0 1 1 2 0v2.8l3.2-.8v1L14 9.8v2.7l7 4z"/></svg>',
  bus:
    '<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M5 3h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1a2.5 2.5 0 0 1-5 0h-2a2.5 2.5 0 0 1-5 0H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm0 3v6h14V6H5zm3 10a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm8 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2z"/></svg>',
} as const;
---

<section id="planes" class="relative">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ocean-dark">
          {plans.kicker}
        </p>
        <h2 class="mt-2 text-3xl font-bold text-ink md:text-4xl">
          Descubre destinos, hoteles y paquetes para grado 11
        </h2>
        <p class="mt-3 text-sm text-slate-700 md:text-base">
          En Viajer@s de 11 encuentras planes turisticos completos para promociones: vuelos,
          hospedaje, actividades y acompanamiento continuo para estudiantes, familias y colegios.
        </p>
      </div>
      <a
        href={plans.cta.href}
        target="_blank"
        rel="noreferrer"
        class="rounded-full bg-ocean px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:-translate-y-0.5 hover:bg-ocean-dark"
      >
        {plans.cta.label}
      </a>
    </div>

    <div class="plan-grid">
      {plans.cards.map((card, index) => {
        const transportTypes = index === 0 ? (['plane'] as const) : (['plane', 'bus'] as const);
        const isLast = index === plans.cards.length - 1;
        return (
          <article
            class:list={[
              'plan-media-card',
              isLast &&
                'md:col-span-2 md:w-full md:max-w-[26rem] md:justify-self-center lg:col-span-1 lg:col-start-2 lg:max-w-none',
            ]}
          >
            <img
              src={getImageForPlan(index)}
              alt={card.title}
              loading="lazy"
              decoding="async"
              class="plan-media-image"
            />
            <div class="plan-media-overlay" aria-hidden="true"></div>
            <span class="transport-stack" aria-hidden="true">
              {transportTypes.map((type) => (
                <span class="transport-icon">
                  <span set:html={transportIcon[type]} />
                </span>
              ))}
            </span>
            <div class="plan-media-content">
              <span class="plan-media-chip" style={`--chip-color: ${getChipColor(index)};`}>
                {card.label}
              </span>
              <h3 class="mt-3 text-xl font-bold text-white md:text-2xl">{card.title}</h3>
              <p class="mt-2 text-sm text-white/90">{card.description}</p>
              <a
                href={card.pdf.href}
                target="_blank"
                rel="noreferrer"
                class="plan-media-cta mt-4 inline-flex items-center justify-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.08em]"
              >
                Ver plan PDF
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .plan-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .plan-media-card {
    position: relative;
    overflow: hidden;
    min-height: 18.5rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 18px 35px rgba(11, 110, 168, 0.14);
    background: #0f172a;
    isolation: isolate;
  }

  .plan-media-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform 0.5s ease;
  }

  .plan-media-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to top, rgba(2, 15, 31, 0.9) 0%, rgba(2, 15, 31, 0.45) 45%, rgba(2, 15, 31, 0.12) 100%),
      linear-gradient(140deg, rgba(11, 110, 168, 0.1), rgba(244, 109, 79, 0.1));
  }

  .plan-media-content {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 1;
    padding: 1.2rem;
  }

  .plan-media-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.28rem 0.72rem;
    font-size: 0.67rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--chip-color) 82%, #0c263c 18%);
    border: 1px solid color-mix(in srgb, var(--chip-color) 72%, white 28%);
    color: #ffffff;
    text-shadow: 0 1px 2px rgba(2, 15, 31, 0.38);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2);
  }

  .transport-stack {
    position: absolute;
    top: 0.65rem;
    right: 0.7rem;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .transport-icon {
    width: 1.05rem;
    height: 1.05rem;
    color: rgba(255, 255, 255, 0.84);
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
    pointer-events: none;
  }

  .transport-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .plan-media-cta {
    color: #06243a;
    background: color-mix(in srgb, var(--color-mint) 84%, white 16%);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .plan-media-card:hover .plan-media-image {
    transform: scale(1.05);
  }

  .plan-media-card:hover .plan-media-cta {
    transform: translateY(-2px);
    filter: brightness(1.02);
  }

  @media (min-width: 768px) {
    .plan-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .plan-media-card {
      min-height: 20.5rem;
    }
  }

  @media (min-width: 1024px) {
    .plan-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .plan-media-image,
    .plan-media-cta {
      transition: none !important;
    }
  }
</style>
